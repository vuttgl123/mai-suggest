-- =========================================================
-- 14. AUTO CREATE PROFILE AFTER GOOGLE LOGIN
-- =========================================================

create or replace function public.handle_new_user()
returns trigger
language plpgsql
security definer
set search_path = ''
as $$
declare
  allowed_user public.allowed_users%rowtype;
begin
  select *
  into allowed_user
  from public.allowed_users
  where email = lower(new.email)
    and is_active = true;

  insert into public.profiles (
    id,
    email,
    display_name,
    avatar_url,
    role,
    is_active
  )
  values (
    new.id,
    lower(new.email),

    coalesce(
      allowed_user.display_name,
      new.raw_user_meta_data ->> 'full_name',
      new.raw_user_meta_data ->> 'name',
      split_part(coalesce(new.email, ''), '@', 1),
      'Thành viên'
    ),

    coalesce(
      new.raw_user_meta_data ->> 'avatar_url',
      new.raw_user_meta_data ->> 'picture'
    ),

    coalesce(
      allowed_user.role,
      'member'::public.app_role
    ),

    allowed_user.email is not null
  )
  on conflict (id) do update
  set
    email = excluded.email,
    display_name = excluded.display_name,
    avatar_url = excluded.avatar_url,
    role = excluded.role,
    is_active = excluded.is_active,
    updated_at = now();

  return new;
end;
$$;

drop trigger if exists on_auth_user_created_profile
  on auth.users;

create trigger on_auth_user_created_profile
after insert on auth.users
for each row execute function public.handle_new_user();

-- =========================================================
-- 15. SYNC ALLOWED USER CHANGES TO PROFILE
-- =========================================================

create or replace function public.sync_allowed_user_profile()
returns trigger
language plpgsql
security definer
set search_path = ''
as $$
begin
  if tg_op = 'DELETE' then
    update public.profiles
    set
      role = 'member'::public.app_role,
      is_active = false,
      updated_at = now()
    where lower(email) = old.email;

    return old;
  end if;

  update public.profiles
  set
    role = new.role,
    is_active = new.is_active,
    display_name = coalesce(new.display_name, display_name),
    updated_at = now()
  where lower(email) = new.email;

  return new;
end;
$$;

drop trigger if exists sync_allowed_user_profile_trigger
  on public.allowed_users;

create trigger sync_allowed_user_profile_trigger
after insert or update or delete on public.allowed_users
for each row execute function public.sync_allowed_user_profile();

-- =========================================================
-- 16. PRIVATE AUTHORIZATION HELPERS
-- =========================================================

create schema if not exists private;

revoke all on schema private from public;
revoke all on schema private from anon;

grant usage on schema private to authenticated;
grant usage on schema private to service_role;

create or replace function private.is_active_member()
returns boolean
language sql
stable
security definer
set search_path = ''
as $$
  select exists (
    select 1
    from public.profiles
    where id = (select auth.uid())
      and is_active = true
  );
$$;

create or replace function private.is_owner()
returns boolean
language sql
stable
security definer
set search_path = ''
as $$
  select exists (
    select 1
    from public.profiles
    where id = (select auth.uid())
      and is_active = true
      and role = 'owner'::public.app_role
  );
$$;

revoke all on function private.is_active_member() from public;
revoke all on function private.is_owner() from public;

grant execute on function private.is_active_member()
  to authenticated, service_role;

grant execute on function private.is_owner()
  to authenticated, service_role;

