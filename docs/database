end
$$;

do $$
begin
  create type public.item_kind as enum (
    'place',
    'product',
    'experience',
    'article',
    'other'
  );
exception
  when duplicate_object then null;
end
$$;

do $$
begin
  create type public.item_link_type as enum (
    'website',
    'map',
    'menu',
    'review',
    'facebook',
    'instagram',
    'tiktok',
    'shopping',
    'other'
