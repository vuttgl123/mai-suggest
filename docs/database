  item_id uuid not null
    references public.items(id)
    on delete cascade,

  link_type public.item_link_type not null default 'other',
  title text not null,
  url text not null,

  sort_order integer not null default 0,
  created_at timestamptz not null default now(),

  constraint item_links_sort_order_check
    check (sort_order >= 0),

  constraint item_links_item_url_unique
    unique (item_id, url)
);

-- =========================================================
-- 9. INTERNAL RATINGS
-- Điểm do bạn và người yêu tự đánh giá
-- =========================================================

create table if not exists public.ratings (
  id uuid primary key default gen_random_uuid(),

  item_id uuid not null
    references public.items(id)
    on delete cascade,

  user_id uuid not null
    references public.profiles(id)
    on delete cascade,

  score smallint not null,
  note text,

  created_at timestamptz not null default now(),
  updated_at timestamptz not null default now(),

  constraint ratings_score_check
    check (score between 1 and 5),

  constraint ratings_note_length_check
    check (
      note is null
      or char_length(note) <= 1000
    ),

  constraint ratings_item_user_unique
    unique (item_id, user_id)
);

-- =========================================================
-- 10. COMMENTS
-- =========================================================

